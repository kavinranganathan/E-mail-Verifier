{
  "name": "email-verifier",
  "version": "0.1.0",
  "private": true,
  "description": "Fast email verification API with an inline signup widget and great DX.",
  "type": "module",
  "bin": {
    "verify": "./dist/bin/verify.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "cli": "tsx bin/verify.ts",
    "serve": "tsx scripts/dev-server.ts",
    "dev": "vercel dev"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vercel/node": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
